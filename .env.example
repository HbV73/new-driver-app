# Copy to ``.env`` locally (never commit ``.env``). Add the same keys as GitHub Actions secrets.
#
# --- Auth: Supabase vs Arxmod REST (MySQL ``auth_users``) ---
# Drivers created in the Arxmod dispatcher live in MySQL — use REST login:
#   VITE_DRIVER_API_PROVIDER=rest
#   VITE_DRIVER_API_BASE_URL=https://apis.germanwm.de
# No trailing slash on the base URL; paths use ``/api/v1/...``.
# The login field is the API ``username``: phone, email, or driver_code (as saved in admin).
#
# Optional: keep Supabase keys if you still use Supabase for something else.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_key
VITE_DRIVER_API_PROVIDER=rest
VITE_DRIVER_API_BASE_URL=https://apis.germanwm.de
